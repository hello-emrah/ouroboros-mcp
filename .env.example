# Comma-separated list of account keys (any names you choose)
INSTAGRAM_ACCOUNTS=koda,emrah

# Per-account credentials — repeat this block for each key above
INSTAGRAM_KODA_TOKEN=
INSTAGRAM_KODA_USER_ID=

INSTAGRAM_EMRAH_TOKEN=
INSTAGRAM_EMRAH_USER_ID=

# Meta App (parent app)
META_APP_ID=
META_APP_SECRET=

# Instagram sub-app (required for token refresh via graph.instagram.com)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
